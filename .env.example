# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Credentials: Required to link the local client to your Supabase PostgreSQL database.
VITE_SUPABASE_URL="https://your-supabase-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-role-token-key"

# Cloudflare Worker URL: Backend API endpoint for D1 SQL database and CRUD operations
VITE_CLOUDFLARE_WORKER_URL="https://your-worker.your-subdomain.workers.dev"

# Google Sign-In & Security Configuration
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
JWT_SECRET="your-jwt-signing-secret"

# ImgBB API Key: (Optional) To upload payment proofs screenshot to ImgBB
VITE_IMGBB_API_KEY=""

# Appwrite Credentials
VITE_APPWRITE_ENDPOINT="https://admin.sorat.in/v1"
VITE_APPWRITE_PROJECT_ID="6a4e644b001268fb3a25"
VITE_APPWRITE_DATABASE_ID="main"
VITE_APPWRITE_USERS_COLLECTION_ID="users"
VITE_APPWRITE_PROOFS_COLLECTION_ID="payment_proofs"
VITE_APPWRITE_BUCKET_ID="screenshots"


