rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Deposits (payment screenshots uploaded by users)
    match /deposits/{allPaths=**} {
      // Authenticated users and admins can read and write
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.resource.size < 10 * 1024 * 1024 
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Banners (readable by everyone, writable by authenticated users)
    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null 
                   && request.resource.size < 10 * 1024 * 1024 
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Thumbnails (including customized slot symbols and app logos)
    match /thumbnails/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null 
                   && request.resource.size < 10 * 1024 * 1024 
                   && request.resource.contentType.matches('image/.*');
    }
    
    // General Uploads
    match /uploads/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null 
                   && request.resource.size < 10 * 1024 * 1024 
                   && request.resource.contentType.matches('image/.*');
    }

    // Default fallback rules
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
